# ═══════════════════════════════════════════
# MarketAI - Variables de Entorno
# ═══════════════════════════════════════════
# Copia este archivo a .env y completa tus keys
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# ── DeepSeek (OBLIGATORIO - motor de decisión) ──
DEEPSEEK_API_KEY=sk-tu-api-key-aqui
DEEPSEEK_MODEL=deepseek-v4-pro

# ── News APIs ──
NEWSAPI_KEY=tu-key-aqui
CRYPTOPANIC_KEY=tu-key-aqui

# ── Polymarket (opcional, solo para ejecución real) ──
# Crear API key en: https://clob.polymarket.com
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=...
POLYMARKET_API_SECRET=...
POLYMARKET_API_PASSPHRASE=...
# Red: polygon (mainnet) | amoy (testnet)
POLYMARKET_CHAIN_ID=137

# ── Polyscan (opcional, para análisis on-chain) ──
# API key gratuita en: https://polyscan.com/apis
POLYSCAN_API_KEY=...

# ── Alpaca (opcional, solo para Forex/Acciones real) ──
# https://alpaca.markets
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...
# paper = true para paper trading de Alpaca
ALPACA_PAPER=true

# ── OANDA (opcional, para Forex real) ──
# https://developer.oanda.com
OANDA_API_KEY=...
OANDA_ACCOUNT_ID=...

# ── Telegram (opcional - alertas) ──
# Crear bot con: https://t.me/BotFather
# Obtener chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Discord (opcional - alertas) ──
# Crear webhook en: Canal → Integraciones → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
